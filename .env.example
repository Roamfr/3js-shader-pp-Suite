# Claude API Key for GLSL shader generation
# Get yours at: https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model to use for shader generation (default: claude-sonnet-4-6)
# Options: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5-20251001
VITE_ANTHROPIC_MODEL=claude-opus-4-6
